  "main": "index.ts",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "prepare": "tsc && tsc-alias",
    "build": "tsc && tsc-alias",
    "setup": "npm install",
    "start": "npx tsx index.ts",
    "start:js": "node dest/index.js",
    "dev": "cross-env NODE_ENV=development npx tsx .",
    "dev:js": "cross-env NODE_ENV=development node dest/index.js"
  },
